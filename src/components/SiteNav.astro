---
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const links = [
  { href: '/',         label: 'Home' },
  { href: '/cortex',   label: 'Cortex' },
  { href: '/mercury',  label: 'Mercury' },
  { href: '/gemma',    label: 'Gemma' },
];
---
<nav class="sitenav" aria-label="Primary">
  {links.map((l) => (
    <a href={l.href} class:list={[{ active: path === l.href }]}>{l.label}</a>
  ))}
</nav>

<style>
  .sitenav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--rtk-sp-2) var(--rtk-sp-5);
    justify-content: center;
    padding: var(--rtk-sp-4) var(--rtk-sp-6);
    border-bottom: 1px solid var(--rtk-border);
    font-family: var(--rtk-font-sans);
    font-size: var(--rtk-fs-sm);
    letter-spacing: 0.02em;
  }
  .sitenav a {
    color: var(--rtk-text-muted);
    border-bottom: 1px solid transparent;
    padding-bottom: 2px;
  }
  .sitenav a:hover { color: var(--rtk-text); border-bottom-color: var(--rtk-border-strong); }
  .sitenav a.active { color: var(--rtk-cardinal-bright); border-bottom-color: var(--rtk-cardinal); }
</style>
